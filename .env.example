VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places API — enables smart city/location autocomplete in the dashboard.
# Without this key the Location field works as a plain text input.
# Setup: https://console.cloud.google.com → Enable "Places API" + "Maps JavaScript API"
VITE_GOOGLE_MAPS_API_KEY=your-google-places-api-key
